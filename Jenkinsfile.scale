pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Point kubectl to Minikube') {
            steps {
                bat 'kubectl config use-context minikube'
            }
        }

        stage('Scale Pod Resources') {
            steps {
                bat '"C:\\Program Files\\Git\\bin\\bash.exe" -c "scripts/scale-resource.sh"'
            }
        }
    }
}
